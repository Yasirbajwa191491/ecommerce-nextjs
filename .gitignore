# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (root and nested workspaces)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
out/

# production
build/
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# convex generated local state
.convex/

# AI worker — model caches and heavy runtime data
services/review-ai-worker/node_modules/
services/review-ai-worker/.cache/
**/.cache/huggingface/
**/.cache/transformers/
*.onnx
*.onnx.data
*.bin
*.safetensors
*.gguf

# docker / ollama local volumes (if created beside compose)
ollama_data/
transformers_cache/

# logs and temp
*.log
tmp/
temp/
